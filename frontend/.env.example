# ReconSentinel Frontend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# All variables exposed to the browser MUST be prefixed with VITE_

# ─── API Base URL (optional override) ────────────────────────────────────────
# Default: Vite dev proxy routes /api → http://localhost:8000
# Override only if deploying with a custom backend URL.
# VITE_API_BASE_URL=http://localhost:8000
